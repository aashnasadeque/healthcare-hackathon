# =============================================================================
# Healthcare Hackathon — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Server ---
PORT=8000
DEBUG=true
RELOAD=true

# --- CORS ---
# Comma-separated list of allowed origins for the API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# --- FHIR Server (optional) ---
# Point to a sandbox FHIR server, e.g. HAPI FHIR or Smile CDR
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# --- Database (optional) ---
DATABASE_URL=sqlite:///./hackathon.db

# --- ML Model ---
# Path to a saved model artifact, if loading from disk
MODEL_PATH=models/saved/model.joblib

# --- API Keys (add as needed) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
